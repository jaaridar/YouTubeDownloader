<Window x:Class="YouTubeDownloader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="YouTube Downloader"
        Height="620" Width="560"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseDown">

    <Border Background="{StaticResource BgColor}" CornerRadius="12">
        <Border.Resources>
            <!-- Custom Toggle Switch Style -->
            <Style x:Key="ToggleSwitch" TargetType="CheckBox">
                <Setter Property="Width" Value="48"/>
                <Setter Property="Height" Value="26"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="CheckBox">
                            <Border x:Name="ToggleBg" CornerRadius="13"
                                    Background="#555"
                                    BorderThickness="0"
                                    Width="48" Height="26"
                                    Cursor="Hand">
                                <Ellipse x:Name="ToggleThumb" Width="20" Height="20"
                                         Fill="White" HorizontalAlignment="Left" Margin="3,0,0,0"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="ToggleBg" Property="Background" Value="{StaticResource PrimaryColor}"/>
                                    <Setter TargetName="ToggleThumb" Property="HorizontalAlignment" Value="Right"/>
                                    <Setter TargetName="ToggleThumb" Property="Margin" Value="0,0,3,0"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Border.Resources>

        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>  <!-- Title bar -->
                <RowDefinition Height="*"/>    <!-- Content -->
            </Grid.RowDefinitions>

            <!-- ====== CUSTOM TITLE BAR ====== -->
            <Border Grid.Row="0" Background="{StaticResource SurfaceColor}"
                    CornerRadius="12,12,0,0">
                <Grid>
                    <TextBlock Text="🎬  YouTube Downloader"
                               Foreground="{StaticResource TextColor}"
                               FontSize="13" FontFamily="Segoe UI"
                               VerticalAlignment="Center" Margin="16,0,0,0"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Center" Margin="0,0,8,0">
                        <TextBlock Text="─" FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource TextMutedColor}"
                                   Cursor="Hand" Margin="4,0"
                                   MouseLeftButtonDown="Minimize_Click"/>
                        <TextBlock Text="✕" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource TextMutedColor}"
                                   Cursor="Hand" Margin="4,0"
                                   MouseLeftButtonDown="Close_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ====== MAIN CONTENT ====== -->
            <ScrollViewer Grid.Row="1" Background="{StaticResource BgColor}"
                          BorderThickness="0" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="24,12,24,16">

                    <!-- URL Input -->
                    <TextBlock Text="📎  Video URL" FontSize="14" FontWeight="Bold"
                               Foreground="{StaticResource TextColor}" Margin="0,8,0,6"/>
                    <TextBox x:Name="UrlTextBox" Style="{StaticResource ModernTextBox}"
                             Text="Paste YouTube URL here..."
                             GotFocus="Url_GotFocus" LostFocus="Url_LostFocus"
                             KeyDown="Url_KeyDown"/>

                    <!-- Section Toggle -->
                    <TextBlock Text="✂️  Section Download" FontSize="14" FontWeight="Bold"
                               Foreground="{StaticResource TextColor}" Margin="0,16,0,6"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <CheckBox x:Name="SectionToggle" Style="{StaticResource ToggleSwitch}"
                                  Checked="Section_Changed" Unchecked="Section_Changed"/>
                        <TextBlock Text="Download specific section"
                                   Foreground="{StaticResource TextMutedColor}"
                                   FontSize="13" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>

                    <!-- Time Inputs -->
                    <Grid x:Name="TimeSection" Visibility="Collapsed" Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Start Time -->
                        <Border Grid.Column="0" Background="{StaticResource SurfaceColor}"
                                CornerRadius="10" Padding="14,12">
                            <StackPanel>
                                <TextBlock Text="START" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource TextMutedColor}"/>
                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="StartH" Grid.Column="0" Text="0"
                                             TextAlignment="Center" FontSize="18" FontWeight="Bold"
                                             FontFamily="Consolas"
                                             Foreground="{StaticResource TextColor}"
                                             Background="{StaticResource Surface2Color}"
                                             BorderBrush="{StaticResource BorderColor}"
                                             BorderThickness="1"
                                             MaxLength="2" PreviewTextInput="NumberOnly_Preview"/>
                                    <TextBlock Grid.Column="1" Text=":" FontSize="16" FontWeight="Bold"
                                               Foreground="{StaticResource TextMutedColor}"
                                               VerticalAlignment="Center" Margin="2,0"/>
                                    <TextBox x:Name="StartM" Grid.Column="2" Text="0"
                                             TextAlignment="Center" FontSize="18" FontWeight="Bold"
                                             FontFamily="Consolas"
                                             Foreground="{StaticResource TextColor}"
                                             Background="{StaticResource Surface2Color}"
                                             BorderBrush="{StaticResource BorderColor}"
                                             BorderThickness="1"
                                             MaxLength="2" PreviewTextInput="NumberOnly_Preview"/>
                                    <TextBlock Grid.Column="3" Text=":" FontSize="16" FontWeight="Bold"
                                               Foreground="{StaticResource TextMutedColor}"
                                               VerticalAlignment="Center" Margin="2,0"/>
                                    <TextBox x:Name="StartS" Grid.Column="4" Text="0"
                                             TextAlignment="Center" FontSize="18" FontWeight="Bold"
                                             FontFamily="Consolas"
                                             Foreground="{StaticResource TextColor}"
                                             Background="{StaticResource Surface2Color}"
                                             BorderBrush="{StaticResource BorderColor}"
                                             BorderThickness="1"
                                             MaxLength="2" PreviewTextInput="NumberOnly_Preview"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Arrow -->
                        <TextBlock Grid.Column="1" Text="→" FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryColor}"
                                   VerticalAlignment="Center" Margin="12,8"/>

                        <!-- End Time -->
                        <Border Grid.Column="2" Background="{StaticResource SurfaceColor}"
                                CornerRadius="10" Padding="14,12">
                            <StackPanel>
                                <TextBlock Text="END" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource TextMutedColor}"/>
                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="EndH" Grid.Column="0" Text="0"
                                             TextAlignment="Center" FontSize="18" FontWeight="Bold"
                                             FontFamily="Consolas"
                                             Foreground="{StaticResource TextColor}"
                                             Background="{StaticResource Surface2Color}"
                                             BorderBrush="{StaticResource BorderColor}"
                                             BorderThickness="1"
                                             MaxLength="2" PreviewTextInput="NumberOnly_Preview"/>
                                    <TextBlock Grid.Column="1" Text=":" FontSize="16" FontWeight="Bold"
                                               Foreground="{StaticResource TextMutedColor}"
                                               VerticalAlignment="Center" Margin="2,0"/>
                                    <TextBox x:Name="EndM" Grid.Column="2" Text="1"
                                             TextAlignment="Center" FontSize="18" FontWeight="Bold"
                                             FontFamily="Consolas"
                                             Foreground="{StaticResource TextColor}"
                                             Background="{StaticResource Surface2Color}"
                                             BorderBrush="{StaticResource BorderColor}"
                                             BorderThickness="1"
                                             MaxLength="2" PreviewTextInput="NumberOnly_Preview"/>
                                    <TextBlock Grid.Column="3" Text=":" FontSize="16" FontWeight="Bold"
                                               Foreground="{StaticResource TextMutedColor}"
                                               VerticalAlignment="Center" Margin="2,0"/>
                                    <TextBox x:Name="EndS" Grid.Column="4" Text="0"
                                             TextAlignment="Center" FontSize="18" FontWeight="Bold"
                                             FontFamily="Consolas"
                                             Foreground="{StaticResource TextColor}"
                                             Background="{StaticResource Surface2Color}"
                                             BorderBrush="{StaticResource BorderColor}"
                                             BorderThickness="1"
                                             MaxLength="2" PreviewTextInput="NumberOnly_Preview"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Download Button -->
                    <Button x:Name="DownloadBtn" Style="{StaticResource PrimaryButton}"
                            Content="⬇  DOWNLOAD HIGH QUALITY"
                            Click="Download_Click"/>

                    <!-- Info Card -->
                    <Border Background="{StaticResource SurfaceColor}"
                            CornerRadius="10" Margin="0,14,0,0"
                            BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="1"
                            Padding="16,14">
                        <StackPanel>
                            <TextBlock x:Name="TitleLabel" Text="Ready to download 🚀"
                                       FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource TextColor}"
                                       TextWrapping="Wrap"/>
                            <TextBlock x:Name="MetaLabel" Text="Paste a YouTube URL above and click download"
                                       FontSize="12"
                                       Foreground="{StaticResource TextMutedColor}"
                                       Margin="0,4,0,0" TextWrapping="Wrap"/>
                            <TextBlock x:Name="SizeLabel" Text=""
                                       FontSize="12"
                                       Foreground="{StaticResource PrimaryColor}"
                                       Margin="0,2,0,0"/>

                            <!-- Progress Bar -->
                            <Border x:Name="ProgressFrame" Background="{StaticResource Surface2Color}"
                                    CornerRadius="10" Height="24" Margin="0,12,0,0"
                                    BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                                <Grid>
                                    <Border x:Name="ProgressFill" Background="{StaticResource PrimaryColor}"
                                            CornerRadius="10" HorizontalAlignment="Left" Width="0"/>
                                    <TextBlock x:Name="ProgressText" Text="0%"
                                               Foreground="{StaticResource WhiteColor}"
                                               FontSize="11" FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- Progress Details -->
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="SpeedLabel" Grid.Column="0"
                                           Text="⚡ ---" FontSize="10"
                                           Foreground="{StaticResource TextMutedColor}"/>
                                <TextBlock x:Name="EtaLabel" Grid.Column="1"
                                           Text="⏳ ---" FontSize="10"
                                           Foreground="{StaticResource TextMutedColor}"/>
                                <TextBlock x:Name="SizeProgressLabel" Grid.Column="2"
                                           Text="📦 ---" FontSize="10"
                                           Foreground="{StaticResource TextMutedColor}"
                                           TextAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Open Folder Button -->
                    <Button Style="{StaticResource SecondaryButton}"
                            Content="📁  Open Downloads Folder"
                            Click="OpenFolder_Click"
                            Margin="0,10,0,0"
                            HorizontalAlignment="Left"/>

                    <!-- Footer -->
                    <TextBlock Text="Made with ❤  ·  yt-dlp"
                               FontSize="10"
                               Foreground="#555"
                               Margin="0,14,0,0"
                               HorizontalAlignment="Right"/>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>