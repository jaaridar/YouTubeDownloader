<Window x:Class="YouTubeDownloader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="YouTube Downloader Pro"
        Height="950" Width="720"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- Modern ComboBox Style -->
        <!-- Modern ComboBox Style -->
        <Style x:Key="PremiumCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="#151525"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#202040"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" 
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Grid.ColumnSpan="2">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="14">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Path Grid.Column="1" Data="M0,0 L5,5 L10,0" Stroke="#606080" StrokeThickness="2" 
                                                      Margin="0,0,15,0" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter HorizontalAlignment="Left" Margin="{TemplateBinding Padding}" 
                                              VerticalAlignment="Center" IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"/>
                            <Popup x:Name="PART_Popup" AllowsTransparency="True" IsOpen="{TemplateBinding IsDropDownOpen}" 
                                   Placement="Bottom" PopupAnimation="Slide">
                                <Border Background="#0F0F1E" BorderBrush="#202040" BorderThickness="1" 
                                        CornerRadius="12" MaxHeight="300" Margin="0,5,0,5"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer SnapsToDevicePixels="True">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="itemBorder" Background="{TemplateBinding Background}" CornerRadius="8" Margin="4,2">
                            <ContentPresenter Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="itemBorder" Property="Background" Value="#252545"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="itemBorder" Property="Background" Value="{StaticResource MainGradient}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toggle Switch Style -->
        <Style x:Key="ModernToggle" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="bg" Width="44" Height="22" Background="#202040" CornerRadius="11" Cursor="Hand">
                                <Ellipse x:Name="dot" Width="16" Height="16" Fill="White" HorizontalAlignment="Left" Margin="3,0"/>
                            </Border>
                            <ContentPresenter Margin="12,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{StaticResource MainGradient}"/>
                                <Setter TargetName="dot" Property="HorizontalAlignment" Value="Right"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BgBrush}" CornerRadius="30" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ══════ HEADER ══════ -->
            <Border Grid.Row="0" Background="#0A0A1A" CornerRadius="30,30,0,0" MouseLeftButtonDown="Window_MouseDown">
                <Grid Margin="25,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Path Data="M10,2 L10,22 L22,12 Z" Fill="{StaticResource MainGradient}" Width="20" Height="20" Stretch="Uniform" Margin="0,0,12,0"/>
                        <TextBlock Text="YouTube Downloader Pro" Foreground="White" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource IconOnlyButton}" Content="━" Click="Minimize_Click"/>
                        <Button Style="{StaticResource IconOnlyButton}" Content="✕" Click="Close_Click" Margin="5,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══════ CONTENT ══════ -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" Margin="30,20">
                <StackPanel>
                    <!-- FFmpeg Warning -->
                    <Border x:Name="FfmpegWarning" Background="#20FF3030" BorderBrush="#FF4040" BorderThickness="1" CornerRadius="16" Padding="15" Margin="0,0,0,20" Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="FFmpeg Missing" FontWeight="Bold" Foreground="#FF4040"/>
                                <TextBlock Text="High-quality merging and MP3 conversion are disabled." Foreground="#A0A0A0" FontSize="12"/>
                            </StackPanel>
                            <Button Grid.Column="1" Style="{StaticResource IconOnlyButton}" Content="⚙" Click="FixFfmpeg_Click"/>
                        </Grid>
                    </Border>

                    <!-- URL INPUT -->
                    <TextBlock Text="VIDEO LINK" Foreground="{StaticResource TextMutedBrush}" FontSize="10" FontWeight="Bold" Margin="5,0,0,10"/>
                    <TextBox x:Name="UrlTextBox" Style="{StaticResource GlassTextBox}" Tag="Paste YouTube link here..."
                             GotFocus="Url_GotFocus" LostFocus="Url_LostFocus"
                             KeyDown="Url_KeyDown" TextChanged="Url_TextChanged"/>

                    <!-- PREVIEW CARD -->
                    <Border x:Name="PreviewCard" Background="{StaticResource SurfaceBrush}" CornerRadius="24" Margin="0,25,0,0" Padding="20" Visibility="Collapsed">
                        <StackPanel>
                            <Border CornerRadius="16" Height="300" Background="#050510" ClipToBounds="True">
                                <Grid>
                                    <Image x:Name="ThumbnailImage" Stretch="UniformToFill"/>
                                    <Border Background="#40000000">
                                        <TextBlock Text="PREVIEW READY" Foreground="White" Opacity="0.5" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" FontSize="12"/>
                                    </Border>
                                </Grid>
                            </Border>
                            
                            <Grid Margin="0,15,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel>
                                    <TextBlock x:Name="VideoTitleLabel" Text="Title" Foreground="White" FontSize="18" FontWeight="Bold" MaxHeight="50" TextWrapping="Wrap"/>
                                    <TextBlock x:Name="VideoMetaLabel" Text="Channel · Duration" Foreground="{StaticResource TextMutedBrush}" Margin="0,5,0,0"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                                    <Border Background="#1000E5FF" CornerRadius="8" Padding="10,4" VerticalAlignment="Center">
                                        <TextBlock x:Name="VideoSizeLabel" Text="0 MB" Foreground="{StaticResource AccentBrush}" FontWeight="Bold" FontSize="12"/>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                                <Button x:Name="DownloadThumbBtn" Style="{StaticResource IconOnlyButton}" Width="Auto" Height="Auto" Padding="12,6" Click="DownloadThumb_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="M19,9h-4V3H9v6H5l7,7L19,9z M5,18v2h14v-2H5z" Fill="{StaticResource TextMutedBrush}" Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0"/>
                                        <TextBlock Text="Save Thumbnail" FontSize="11" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- SETTINGS -->
                    <Border Background="{StaticResource SurfaceBrush}" CornerRadius="24" Margin="0,25,0,0" Padding="25">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="QUALITY" Foreground="{StaticResource TextMutedBrush}" FontSize="10" FontWeight="Bold" Margin="5,0,0,10"/>
                                    <ComboBox x:Name="QualityCombo" Style="{StaticResource PremiumCombo}" SelectedIndex="6">
                                        <ComboBoxItem>8K Ultra HD</ComboBoxItem>
                                        <ComboBoxItem>4K Ultra HD</ComboBoxItem>
                                        <ComboBoxItem>2K Quad HD</ComboBoxItem>
                                        <ComboBoxItem>1080p Full HD</ComboBoxItem>
                                        <ComboBoxItem>720p HD</ComboBoxItem>
                                        <ComboBoxItem>480p SD</ComboBoxItem>
                                        <ComboBoxItem>Best Available</ComboBoxItem>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="FORMAT" Foreground="{StaticResource TextMutedBrush}" FontSize="10" FontWeight="Bold" Margin="5,0,0,10"/>
                                    <ComboBox x:Name="FormatCombo" Style="{StaticResource PremiumCombo}" SelectedIndex="0">
                                        <ComboBoxItem Tag="video+audio">🎬 MP4 Video</ComboBoxItem>
                                        <ComboBoxItem Tag="audio">🎵 MP3 Audio</ComboBoxItem>
                                        <ComboBoxItem Tag="video">🎬 MP4 (No Audio)</ComboBoxItem>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <Border Height="1" Background="#202040" Margin="0,25"/>

                            <!-- SEGMENT SELECTION -->
                            <Grid Margin="0,0,0,15">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12.5,7V12.25L17,14.92L16.25,16.15L11,13V7H12.5Z" Fill="{StaticResource AccentBrush}" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0"/>
                                    <TextBlock Text="DOWNLOAD SPECIFIC SECTION" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                                <CheckBox x:Name="SectionToggle" Style="{StaticResource ModernToggle}" HorizontalAlignment="Right" Checked="Section_Changed" Unchecked="Section_Changed"/>
                            </Grid>

                            <StackPanel x:Name="TimeSection" Visibility="Collapsed">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="START TIME" Foreground="{StaticResource TextMutedBrush}" FontSize="9" Margin="5,0,0,8"/>
                                        <TextBox x:Name="StartTimeInput" Style="{StaticResource GlassTextBox}" Text="00:00:00" Height="45" TextChanged="TimeInput_TextChanged" PreviewTextInput="NumberOnly_Preview"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="END TIME" Foreground="{StaticResource TextMutedBrush}" FontSize="9" Margin="5,0,0,8"/>
                                        <TextBox x:Name="EndTimeInput" Style="{StaticResource GlassTextBox}" Text="00:00:00" Height="45" TextChanged="TimeInput_TextChanged" PreviewTextInput="NumberOnly_Preview"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Timeline Sliders -->
                                <Grid Margin="0,20,0,0" PreviewMouseDown="SliderGrid_PreviewMouseDown" PreviewMouseLeftButtonUp="SliderGrid_PreviewMouseUp">
                                    <Border Height="6" Background="#101025" CornerRadius="3" VerticalAlignment="Center" Margin="10,0"/>
                                    
                                    <!-- Range Highlight -->
                                    <Border x:Name="SliderRangeFill" Height="6" Background="{StaticResource MainGradient}" CornerRadius="3" VerticalAlignment="Center" HorizontalAlignment="Left" Width="0" Margin="10,0">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="10" Color="{StaticResource AccentColorRaw}" Opacity="0.4" ShadowDepth="0"/>
                                        </Border.Effect>
                                    </Border>

                                    <Slider x:Name="StartSlider" Style="{StaticResource ModernSlider}" Maximum="100" Value="0" VerticalAlignment="Center" ValueChanged="Slider_ValueChanged"/>
                                    <Slider x:Name="EndSlider" Style="{StaticResource ModernSlider}" Maximum="100" Value="100" VerticalAlignment="Center" ValueChanged="Slider_ValueChanged"/>

                                    <!-- Duration Bubble -->
                                    <Canvas IsHitTestVisible="False">
                                        <Border x:Name="DurationBubble" Background="{StaticResource MainGradient}" CornerRadius="10" Padding="8,3" Canvas.Top="-30">
                                            <TextBlock x:Name="DurationBubbleText" Text="00:00" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="8" Opacity="0.3" ShadowDepth="2"/>
                                            </Border.Effect>
                                        </Border>
                                    </Canvas>
                                </Grid>
                            </StackPanel>

                            <Border Height="1" Background="#202040" Margin="0,25"/>

                            <!-- ACTION BUTTONS (PLAY/OPEN) -->
                            <StackPanel x:Name="DownloadActions" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0" Visibility="Collapsed">
                                <Button Style="{StaticResource IconOnlyButton}" Margin="0,0,10,0" Click="PlayVideo_Click" Padding="15,8">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="M8,5.14V19.14L19,12.14L8,5.14Z" Fill="{StaticResource AccentBrush}" Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0"/>
                                        <TextBlock Text="PLAY VIDEO" Foreground="{StaticResource AccentBrush}" FontWeight="Bold" FontSize="11"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource IconOnlyButton}" Click="OpenFolder_Click" Padding="15,8">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="M10,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8C22,6.89 21.1,6 20,6H12L10,4Z" Fill="{StaticResource TextMutedBrush}" Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0"/>
                                        <TextBlock Text="OPEN FOLDER" Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- DOWNLOAD BUTTON -->
                    <Button x:Name="DownloadBtn" Style="{StaticResource ModernButton}" Margin="0,30,0,0" Click="Download_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M12,2 L12,15 M5,10 L12,17 L19,10 M2,20 L22,20" Stroke="White" StrokeThickness="3" Width="18" Height="18" Stretch="Uniform" Margin="0,0,15,0"/>
                            <TextBlock x:Name="DownloadBtnText" Text="INITIALIZE DOWNLOAD" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- PROGRESS CARD -->
                    <Border x:Name="StatusCard" Background="{StaticResource SurfaceBrush}" CornerRadius="24" Margin="0,25,0,0" Padding="25">
                        <StackPanel>
                            <Grid>
                                <TextBlock x:Name="TitleLabel" Text="Ready to Download" Foreground="White" FontSize="16" FontWeight="Bold"/>
                                <TextBlock x:Name="ProgressText" Text="0%" Foreground="{StaticResource AccentBrush}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Right"/>
                            </Grid>
                            <TextBlock x:Name="MetaLabel" Text="Waiting for link..." Foreground="{StaticResource TextMutedBrush}" Margin="0,5,0,15"/>
                            
                            <Grid Height="12">
                                <Border Background="#101025" CornerRadius="6"/>
                                <Border x:Name="ProgressFill" Background="{StaticResource MainGradient}" CornerRadius="6" HorizontalAlignment="Left" Width="0">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="15" Color="{StaticResource AccentColorRaw}" Opacity="0.5" ShadowDepth="0"/>
                                    </Border.Effect>
                                </Border>
                            </Grid>

                            <Grid Margin="0,20,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="SPEED" FontSize="9" Foreground="{StaticResource TextMutedBrush}" FontWeight="Bold"/>
                                    <TextBlock x:Name="SpeedLabel" Text="---" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,4,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <TextBlock Text="ETA" FontSize="9" Foreground="{StaticResource TextMutedBrush}" FontWeight="Bold"/>
                                    <TextBlock x:Name="EtaLabel" Text="---" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,4,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                    <TextBlock Text="SIZE" FontSize="9" Foreground="{StaticResource TextMutedBrush}" FontWeight="Bold"/>
                                    <TextBlock x:Name="SizeProgressLabel" Text="---" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- BOTTOM BAR -->
                    <Grid Margin="0,30,0,0">
                        <Button Style="{StaticResource IconOnlyButton}" Width="Auto" Padding="15,0" Click="OpenFolder_Click">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M3,7 L3,18 C3,19.1 3.9,20 5,20 L19,20 C20.1,20 21,19.1 21,18 L21,9 C21,7.9 20.1,7 19,7 L12,7 L10,5 L5,5 C3.9,5 3,5.9 3,7 Z" 
                                      Fill="{StaticResource TextMutedBrush}" Width="16" Height="16" Stretch="Uniform" Margin="0,0,10,0"/>
                                <TextBlock Text="Downloads Folder" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button Style="{StaticResource IconOnlyButton}" Width="Auto" Padding="15,0" Click="UpdateEngine_Click">
                                <TextBlock Text="Update Engine" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                            </Button>
                            <TextBlock Text="Made with ❤️" FontSize="11" Foreground="#303050" Margin="15,0,0,0"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>