<Window x:Class="YouTubeDownloader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="YouTube Downloader Pro"
        Height="720" Width="580"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseDown">

    <Border Background="{StaticResource BgColor}" CornerRadius="14">
        <Border.Resources>

            <!-- Toggle Switch -->
            <Style x:Key="ToggleSwitch" TargetType="CheckBox">
                <Setter Property="Width" Value="48"/><Setter Property="Height" Value="26"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="CheckBox">
                            <Border x:Name="ToggleBg" CornerRadius="13" Background="#555" BorderThickness="0" Width="48" Height="26" Cursor="Hand">
                                <Ellipse x:Name="ToggleThumb" Width="20" Height="20" Fill="White" HorizontalAlignment="Left" Margin="3,0,0,0"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="ToggleBg" Property="Background" Value="{StaticResource PrimaryColor}"/>
                                    <Setter TargetName="ToggleThumb" Property="HorizontalAlignment" Value="Right"/>
                                    <Setter TargetName="ToggleThumb" Property="Margin" Value="0,0,3,0"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ComboBox -->
            <Style x:Key="ModernCombo" TargetType="ComboBox">
                <Setter Property="Background" Value="{StaticResource Surface2Color}"/>
                <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Height" Value="38"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBox">
                            <Grid>
                                <Border x:Name="border" Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="8">
                                    <Grid>
                                        <ContentPresenter x:Name="contentPresenter" Margin="12,0,30,0"
                                                          HorizontalAlignment="Left" VerticalAlignment="Center"
                                                          Content="{TemplateBinding SelectionBoxItem}"
                                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"/>
                                        <Path x:Name="arrow" Data="M0,0 L8,0 L4,5 Z" Fill="{StaticResource TextMutedColor}"
                                              HorizontalAlignment="Right" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                <Popup x:Name="PART_Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                                       AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                    <Border Background="{StaticResource SurfaceColor}" BorderBrush="{StaticResource BorderColor}"
                                            BorderThickness="1" CornerRadius="8" MaxHeight="200">
                                        <ScrollViewer>
                                            <ItemsPresenter Margin="4"/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="HasItems" Value="False">
                                    <Setter TargetName="border" Property="Opacity" Value="0.6"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ComboBoxItem -->
            <Style TargetType="ComboBoxItem">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="Padding" Value="10,8"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBoxItem">
                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{StaticResource Surface2Color}"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{StaticResource PrimaryColor}"/>
                                    <Setter Property="Foreground" Value="{StaticResource WhiteColor}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        </Border.Resources>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ══════ TITLE BAR ══════ -->
            <Border Grid.Row="0" Background="{StaticResource SurfaceColor}" CornerRadius="14,14,0,0">
                <Grid>
                    <TextBlock Text="🎬  YouTube Downloader Pro" Foreground="{StaticResource TextColor}"
                               FontSize="13" FontFamily="Segoe UI" VerticalAlignment="Center" Margin="16,0,0,0"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0">
                        <TextBlock Text="─" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextMutedColor}"
                                   Cursor="Hand" Margin="4,0" MouseLeftButtonDown="Minimize_Click"/>
                        <TextBlock Text="✕" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextMutedColor}"
                                   Cursor="Hand" Margin="4,0" MouseLeftButtonDown="Close_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══════ MAIN CONTENT ══════ -->
            <ScrollViewer Grid.Row="1" Background="{StaticResource BgColor}" BorderThickness="0" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20,8,20,16">

                    <!-- ===== URL SECTION ===== -->
                    <TextBlock Text="📎  Video URL" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextColor}" Margin="0,6,0,6"/>
                    <Grid>
                        <TextBox x:Name="UrlTextBox" Style="{StaticResource ModernTextBox}" Height="42"
                                 Text="Paste YouTube URL here..."
                                 GotFocus="Url_GotFocus" LostFocus="Url_LostFocus"
                                 KeyDown="Url_KeyDown" TextChanged="Url_TextChanged"/>
                    </Grid>

                    <!-- ===== VIDEO PREVIEW ===== -->
                    <Border x:Name="PreviewCard" Background="{StaticResource SurfaceColor}" CornerRadius="12"
                            BorderBrush="{StaticResource BorderColor}" BorderThickness="1"
                            Margin="0,12,0,0" Padding="14" Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" CornerRadius="8" Width="160" Height="90" Background="{StaticResource Surface2Color}" ClipToBounds="True">
                                <Image x:Name="ThumbnailImage" Width="160" Height="90" Stretch="UniformToFill"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                                <TextBlock x:Name="VideoTitleLabel" Text="" FontSize="13" FontWeight="Bold"
                                           Foreground="{StaticResource TextColor}" TextWrapping="Wrap" MaxHeight="38"/>
                                <TextBlock x:Name="VideoMetaLabel" Text="" FontSize="11" Foreground="{StaticResource TextMutedColor}" Margin="0,4,0,0"/>
                                <TextBlock x:Name="VideoSizeLabel" Text="" FontSize="11" Foreground="{StaticResource PrimaryColor}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ===== SETTINGS CARD ===== -->
                    <Border Background="{StaticResource SurfaceColor}" CornerRadius="12"
                            BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Margin="0,12,0,0" Padding="16,14">
                        <StackPanel>

                            <TextBlock Text="⚙️  Download Settings" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextColor}" Margin="0,0,0,12"/>

                            <!-- Quality + Format Row -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Quality" FontSize="11" Foreground="{StaticResource TextMutedColor}" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="QualityCombo" Style="{StaticResource ModernCombo}"
                                              SelectedIndex="2">
                                        <ComboBoxItem>4320p (8K)</ComboBoxItem>
                                        <ComboBoxItem>2160p (4K)</ComboBoxItem>
                                        <ComboBoxItem>1440p (2K)</ComboBoxItem>
                                        <ComboBoxItem>1080p (Full HD)</ComboBoxItem>
                                        <ComboBoxItem>720p (HD)</ComboBoxItem>
                                        <ComboBoxItem>480p (SD)</ComboBoxItem>
                                        <ComboBoxItem>360p</ComboBoxItem>
                                        <ComboBoxItem>Best Available</ComboBoxItem>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Format" FontSize="11" Foreground="{StaticResource TextMutedColor}" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="FormatCombo" Style="{StaticResource ModernCombo}" SelectedIndex="0"
                                              SelectionChanged="Format_Changed">
                                        <ComboBoxItem Tag="video+audio">🎬 Video + Audio (MP4)</ComboBoxItem>
                                        <ComboBoxItem Tag="audio">🎵 Audio Only (MP3)</ComboBoxItem>
                                        <ComboBoxItem Tag="video">🎬 Video Only (No Audio)</ComboBoxItem>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <!-- Compatibility Mode -->
                            <Border x:Name="CompatBar" Background="{StaticResource Surface2Color}" CornerRadius="8"
                                    BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Padding="12,10" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox x:Name="CompatMode" Style="{StaticResource ToggleSwitch}" Grid.Column="0"/>
                                    <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="🔄  After Effects Compatibility" FontSize="12" FontWeight="Bold" Foreground="{StaticResource TextColor}"/>
                                        <TextBlock Text="Forces H.264 + AAC (fixes YouTube Shorts import issues)" FontSize="10" Foreground="{StaticResource TextMutedColor}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Section Toggle -->
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <CheckBox x:Name="SectionToggle" Style="{StaticResource ToggleSwitch}"
                                          Checked="Section_Changed" Unchecked="Section_Changed"/>
                                <TextBlock Text="✂️  Download specific section" Foreground="{StaticResource TextMutedColor}"
                                           FontSize="13" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            </StackPanel>

                            <!-- Time Inputs -->
                            <Grid x:Name="TimeSection" Visibility="Collapsed" Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <!-- Start -->
                                <Border Grid.Column="0" Background="{StaticResource Surface2Color}" CornerRadius="8" Padding="10,8">
                                    <StackPanel>
                                        <TextBlock Text="START" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextMutedColor}"/>
                                        <Grid Margin="0,4,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/><ColumnDefinition Width="Auto"/><ColumnDefinition/><ColumnDefinition Width="Auto"/><ColumnDefinition/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="StartH" Grid.Column="0" Text="0" TextAlignment="Center" FontSize="16" FontWeight="Bold"
                                                     FontFamily="Consolas" Foreground="{StaticResource TextColor}" Background="{StaticResource Surface2Color}"
                                                     BorderBrush="{StaticResource BorderColor}" BorderThickness="1" MaxLength="2" PreviewTextInput="NumberOnly_Preview"/>
                                            <TextBlock Grid.Column="1" Text=":" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextMutedColor}" VerticalAlignment="Center" Margin="1,0"/>
                                            <TextBox x:Name="StartM" Grid.Column="2" Text="0" TextAlignment="Center" FontSize="16" FontWeight="Bold"
                                                     FontFamily="Consolas" Foreground="{StaticResource TextColor}" Background="{StaticResource Surface2Color}"
                                                     BorderBrush="{StaticResource BorderColor}" BorderThickness="1" MaxLength="2" PreviewTextInput="NumberOnly_Preview"/>
                                            <TextBlock Grid.Column="3" Text=":" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextMutedColor}" VerticalAlignment="Center" Margin="1,0"/>
                                            <TextBox x:Name="StartS" Grid.Column="4" Text="0" TextAlignment="Center" FontSize="16" FontWeight="Bold"
                                                     FontFamily="Consolas" Foreground="{StaticResource TextColor}" Background="{StaticResource Surface2Color}"
                                                     BorderBrush="{StaticResource BorderColor}" BorderThickness="1" MaxLength="2" PreviewTextInput="NumberOnly_Preview"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                                <TextBlock Grid.Column="1" Text="→" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" VerticalAlignment="Center" Margin="8,8"/>
                                <!-- End -->
                                <Border Grid.Column="2" Background="{StaticResource Surface2Color}" CornerRadius="8" Padding="10,8">
                                    <StackPanel>
                                        <TextBlock Text="END" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextMutedColor}"/>
                                        <Grid Margin="0,4,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/><ColumnDefinition Width="Auto"/><ColumnDefinition/><ColumnDefinition Width="Auto"/><ColumnDefinition/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="EndH" Grid.Column="0" Text="0" TextAlignment="Center" FontSize="16" FontWeight="Bold"
                                                     FontFamily="Consolas" Foreground="{StaticResource TextColor}" Background="{StaticResource Surface2Color}"
                                                     BorderBrush="{StaticResource BorderColor}" BorderThickness="1" MaxLength="2" PreviewTextInput="NumberOnly_Preview"/>
                                            <TextBlock Grid.Column="1" Text=":" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextMutedColor}" VerticalAlignment="Center" Margin="1,0"/>
                                            <TextBox x:Name="EndM" Grid.Column="2" Text="1" TextAlignment="Center" FontSize="16" FontWeight="Bold"
                                                     FontFamily="Consolas" Foreground="{StaticResource TextColor}" Background="{StaticResource Surface2Color}"
                                                     BorderBrush="{StaticResource BorderColor}" BorderThickness="1" MaxLength="2" PreviewTextInput="NumberOnly_Preview"/>
                                            <TextBlock Grid.Column="3" Text=":" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextMutedColor}" VerticalAlignment="Center" Margin="1,0"/>
                                            <TextBox x:Name="EndS" Grid.Column="4" Text="0" TextAlignment="Center" FontSize="16" FontWeight="Bold"
                                                     FontFamily="Consolas" Foreground="{StaticResource TextColor}" Background="{StaticResource Surface2Color}"
                                                     BorderBrush="{StaticResource BorderColor}" BorderThickness="1" MaxLength="2" PreviewTextInput="NumberOnly_Preview"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </Grid>

                        </StackPanel>
                    </Border>

                    <!-- ===== DOWNLOAD BUTTON ===== -->
                    <Button x:Name="DownloadBtn" Style="{StaticResource PrimaryButton}" Height="52" Margin="0,12,0,0"
                            Content="⬇  DOWNLOAD" Click="Download_Click"/>

                    <!-- ===== STATUS / PROGRESS CARD ===== -->
                    <Border x:Name="StatusCard" Background="{StaticResource SurfaceColor}" CornerRadius="12"
                            BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Margin="0,12,0,0" Padding="16,14"
                            Visibility="Visible">
                        <StackPanel>
                            <!-- Status -->
                            <TextBlock x:Name="TitleLabel" Text="Ready 🚀" FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource TextColor}" TextWrapping="Wrap"/>
                            <TextBlock x:Name="MetaLabel" Text="Paste a URL above to get started"
                                       FontSize="11" Foreground="{StaticResource TextMutedColor}" Margin="0,2,0,0" TextWrapping="Wrap"/>
                            <TextBlock x:Name="SizeLabel" Text="" FontSize="11" Foreground="{StaticResource PrimaryColor}" Margin="0,2,0,0"/>

                            <!-- Progress -->
                            <Border x:Name="ProgressFrame" Background="{StaticResource Surface2Color}" CornerRadius="8"
                                    Height="22" Margin="0,10,0,0" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                                <Grid>
                                    <Border x:Name="ProgressFill" Background="{StaticResource PrimaryColor}" CornerRadius="8"
                                            HorizontalAlignment="Left" Width="0"/>
                                    <TextBlock x:Name="ProgressText" Text="0%" Foreground="{StaticResource WhiteColor}"
                                               FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- Details -->
                            <Grid Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="SpeedLabel" Grid.Column="0" Text="⚡ ---" FontSize="10" Foreground="{StaticResource TextMutedColor}"/>
                                <TextBlock x:Name="EtaLabel" Grid.Column="1" Text="⏳ ---" FontSize="10" Foreground="{StaticResource TextMutedColor}"/>
                                <TextBlock x:Name="SizeProgressLabel" Grid.Column="2" Text="📦 ---" FontSize="10"
                                           Foreground="{StaticResource TextMutedColor}" TextAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ===== BOTTOM CONTROLS ===== -->
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Style="{StaticResource SecondaryButton}"
                                Content="📁  Open Downloads Folder" Click="OpenFolder_Click" HorizontalAlignment="Left"/>
                        <TextBlock Grid.Column="1" Text="Made with ❤  ·  yt-dlp" FontSize="10"
                                   Foreground="#555" VerticalAlignment="Center"/>
                    </Grid>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>